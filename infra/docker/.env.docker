# K.A.O.S Docker Environment Variables
# Copy to .env and customize for your environment

# Application
APP_NAME=K.A.O.S
APP_ENV=production
APP_PORT=8000
LOG_LEVEL=INFO

# Obsidian Vault (mount path in container)
OBSIDIAN_VAULT_PATH=/vault

# Ollama (external - host.docker.internal for Docker Desktop)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_FAST_MODEL=qwen3:4b

# Model IDs (OpenAI compatible)
API_MODEL_ID=kaos-rag
FAST_MODEL_ID=kaos-fast
DEFAULT_MODEL_ID=kaos

# Qdrant (internal Docker network)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=obsidian_memory

# PostgreSQL (internal Docker network)
DATABASE_URL=postgresql://ai-p:ai-admin@postgres:5432/kaos

# Hugging Face Token (for embeddings)
HF_TOKEN=

# RAG Settings
RAG_SCORE_THRESHOLD=0.3
RAG_DEFAULT_LIMIT=5

# Embedding Models
EMBEDDING_MODEL_DEV=nomic-embed-text
EMBEDDING_MODEL_PROD=bge-m3
EMBEDDING_BATCH_SIZE=64
# K.A.O.S Production Docker Environment Variables (Template)
# Used by docker-compose.prod.yml
# Copy this file to .env.prod and fill in your actual values.
# NEVER commit .env.prod to version control.

# Application
APP_NAME=K.A.O.S
APP_ENV=production
APP_PORT=1010
LOG_LEVEL=INFO

# Cloudflare Tunnel Token (generate at https://one.dash.cloudflare.com)
# WARNING: Keep this secret. Never commit it to git.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Workspace (mount path in container — workspace/ is the monorepo workspace dir)
WORKSPACE_ROOT=/workspace

# Obsidian Vault (mount path in container)
OBSIDIAN_VAULT_PATH=/vault

# Ollama (internal Docker network by default, or point to external server if needed)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_FAST_MODEL=qwen3:4b

# Model IDs (OpenAI compatible)
API_MODEL_ID=kaos-rag
FAST_MODEL_ID=kaos-fast
DEFAULT_MODEL_ID=kaos

# Qdrant (internal Docker network)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=obsidian_memory

# PostgreSQL (internal Docker network)
# WARNING: Change the password below for production.
DATABASE_URL=postgresql+psycopg://ai-p:your_strong_password_here@postgres:5432/kaos

# API Key - DEFINE A STRONG SECRET KEY HERE FOR SECURE AUTHENTICATION
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace_with_a_strong_random_key

# Hugging Face Token (for embeddings - required for bge-m3 model)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# RAG Settings
RAG_SCORE_THRESHOLD=0.3
RAG_DEFAULT_LIMIT=5

# Embedding Models
EMBEDDING_MODEL_DEV=nomic-embed-text
EMBEDDING_MODEL_PROD=bge-m3
EMBEDDING_BATCH_SIZE=64

# Grafana
GF_SECURITY_ADMIN_USER=admin
# WARNING: Change this password for production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
GF_SECURITY_ADMIN_PASSWORD=replace_with_a_strong_password

# CORS Origins (adjust or keep defaults for Tauri)
CORS_ORIGINS=["http://localhost:1420","http://localhost:3000","http://localhost:3001","tauri://localhost","http://tauri.localhost","https://tauri.localhost"]

# N8N Integration
N8N_WEBHOOK_URL=http://n8n:5678/webhook/kaos-events
N8N_API_URL=http://n8n:5678
N8N_EVENTS=["workflow_completed","drift.detected","vault.analysis.completed"]

# N8N Authentication (enable for production)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
# WARNING: Change this password for production.
N8N_BASIC_AUTH_PASSWORD=replace_with_a_strong_password

# Open WebUI Authentication (enable for production)
WEBUI_AUTH=true

# Audit scheduler (days between reviews in production)
AUDIT_INTERVAL_DAYS=7

# WhatsApp Integration (Evolution API)
WHATSAPP_API_URL=http://evolution-api:8080
WHATSAPP_API_KEY=

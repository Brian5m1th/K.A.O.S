{
  "title": "K.A.O.S - Overview",
  "uid": "kaos-overview",
  "version": 1,
  "tags": ["kaos", "production"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Requests por minuto",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(kaos_events_total{event_name=\"request_started\"}[1m])",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "title": "Custo acumulado (USD)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "kaos_cost_total_usd",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Latencia de Workflows",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(kaos_workflow_duration_seconds_sum[5m]) / rate(kaos_workflow_duration_seconds_count[5m])",
          "legendFormat": "{{workflow}}"
        }
      ]
    },
    {
      "title": "Erros",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(kaos_events_total{status=\"failed\"}[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "title": "Estado do Circuit Breaker",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "kaos_circuit_breaker_state",
          "legendFormat": "state"
        }
      ]
    },
    {
      "title": "Custo por Provedor",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 16 },
      "targets": [
        {
          "expr": "kaos_cost_total_usd",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "title": "Logs Recentes",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "{job=\"kaos-api\"} |= \"event\"",
          "legendFormat": ""
        }
      ],
      "datasource": "Loki"
    }
  ]
}

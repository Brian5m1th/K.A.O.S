APP_NAME="K.A.O.S"
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

OBSIDIAN_VAULT_PATH=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_FAST_MODEL=qwen3:4b
API_MODEL_ID=kaos-rag
FAST_MODEL_ID=kaos-fast
DEFAULT_MODEL_ID=kaos

# LLM Providers (opcional - apenas se usar cloud)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# MODEL_MAP: mapeia modelo API -> {provider, model}
# Formato: {"gpt-4": {"provider": "openai", "model": "gpt-4"}, "claude-3": {"provider": "claude", "model": "claude-3-sonnet-20240229"}}
# FALLBACK_CHAIN: ordem de fallback, formato "provider:model,provider:model"
# Ex: "openai:gpt-4,claude:claude-3-sonnet-20240229,ollama:qwen3:14b"

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=obsidian_memory

DATABASE_URL=postgresql://user:password@localhost:5432/kaos

# CORS: origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:1420,http://localhost:3000

# N8N: webhook para eventos
N8N_WEBHOOK_URL=
N8N_API_URL=http://n8n:5678
N8N_EVENTS=workflow_completed,drift.detected,vault.analysis.completed

# Audit: intervalo do auto-review (dias, apenas em production)
AUDIT_INTERVAL_DAYS=7

HF_TOKEN=
